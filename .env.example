# ─────────────────────────────────────────────────────────────────────────────
# AIRIS — Environment Configuration Template
#
# Copy this file to .env.local and fill in your values.
# Both .env and .env.local are listed in .gitignore — never commit real secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── General Agent Settings ───────────────────────────────────────────────────

# Logging verbosity. Options: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Maximum number of times the LLM is allowed to self-correct its output
# before the agent raises an error. Increase if you see frequent parse failures.
MAX_SELF_CORRECTION_RETRIES=5

# LLM sampling temperature. Lower values (closer to 0) produce more
# deterministic, consistent recommendations. Range: 0.0 – 1.0
TEMPERATURE=0.2

# ── OpenAI ───────────────────────────────────────────────────────────────────

# Your OpenAI API key. Obtain from https://platform.openai.com/api-keys
OPENAI_API_KEY=<your-openai-api-key>

# Primary reasoning model used for deep analysis and recommendation generation.
OPENAI_DEFAULT_MODEL=gpt-4o

# Lightweight model used for fast discovery tasks (e.g. initial context scraping).
OPENAI_FAST_MODEL=gpt-4o-mini

# ── Google Gemini ─────────────────────────────────────────────────────────────

# Your Google AI Studio API key. Obtain from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=<your-gemini-api-key>

# Primary reasoning model used for deep analysis and recommendation generation.
GEMINI_DEFAULT_MODEL=gemini-2.5-pro

# Lightweight model used for fast discovery tasks.
GEMINI_FAST_MODEL=gemini-3.1-flash-lite-preview

# ── Agent Thresholds ──────────────────────────────────────────────────────────

# PVC claimed capacity (in GiB) above which the storage gate is triggered.
# Any PVC that meets or exceeds this value must carry a written justification
# annotation before the agent will approve the change.
STORAGE_GATE_LIMIT_GI=50
